{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-assisted-sast-benchmark:finding:1.0",
  "title": "AI-assisted SAST finding",
  "description": "Stable normalized finding contract shared by all benchmark experiments.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "experiment_id",
    "tool",
    "harness_version",
    "model",
    "prompt_version",
    "vulnerability_type",
    "cwe",
    "severity",
    "confidence",
    "file",
    "start_line",
    "end_line",
    "function",
    "source",
    "sink",
    "data_flow",
    "description",
    "evidence",
    "attack_scenario",
    "security_control",
    "recommendation",
    "validation_status",
    "validator",
    "validator_confidence",
    "duplicate_of",
    "notes"
  ],
  "properties": {
    "finding_id": {"type": "string"},
    "experiment_id": {"type": "string"},
    "tool": {"type": "string"},
    "harness_version": {"type": "string"},
    "model": {"type": "string"},
    "prompt_version": {"type": "string"},
    "vulnerability_type": {"type": "string"},
    "cwe": {"type": ["string", "null"]},
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "informational"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "file": {"type": "string"},
    "start_line": {"type": ["integer", "null"], "minimum": 1},
    "end_line": {"type": ["integer", "null"], "minimum": 1},
    "function": {"type": ["string", "null"]},
    "source": {"type": ["string", "null"]},
    "sink": {"type": ["string", "null"]},
    "data_flow": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "evidence": {"type": "string"},
    "attack_scenario": {"type": "string"},
    "security_control": {"type": ["string", "null"]},
    "recommendation": {"type": "string"},
    "validation_status": {
      "type": "string",
      "enum": ["unvalidated", "validated", "rejected", "uncertain"]
    },
    "validator": {"type": ["string", "null"]},
    "validator_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "duplicate_of": {"type": ["string", "null"]},
    "notes": {"type": "string"}
  }
}
